# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# OpenAI-compatible API Configuration (LLM)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=z-ai/glm-4.5-air:free

# OpenAI-compatible API Configuration (Embeddings)
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Endee Vector DB (self-hosted Docker — runs on port 8080)
# Start with: docker compose up -d  (from d:\EndeeLIQ\endee\)
ENDEE_URL=http://localhost:8080
ENDEE_AUTH_TOKEN=

# Together AI (optional)
TOGETHER_API_KEY=

# Azure Computer Vision — OCR for scanned PDFs and image uploads
# Sign up: https://portal.azure.com → Cognitive Services → Computer Vision
# Supported formats: JPEG, PNG, BMP, PDF, TIFF (up to 50MB)
AZURE_CV_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_CV_KEY=your-azure-cv-key

# Application Configuration
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
